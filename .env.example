# PostgreSQL connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rehabilitatetomogotchi

# Groq AI chat (optional; chat returns 503 if omitted)
GROQ_API_KEY=your-groq-api-key-here

# JWT — generate something long and random for production
